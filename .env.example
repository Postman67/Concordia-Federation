# Server
PORT=3000
NODE_ENV=development

# PostgreSQL — option A: connection string (Railway / hosted providers)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# PostgreSQL — option B: individual vars (local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=concordia_federation
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Token signing — Ed25519 private key in PKCS8 PEM (EdDSA).
# Generate with: node scripts/generate-keys.js  (prints the single-line form)
# The public half is served automatically at /.well-known/jwks.json
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Identity token lifetime — short, because refresh tokens handle longevity
JWT_EXPIRES_IN=1h

# Refresh token lifetime in days (rotating; reuse revokes the whole family)
REFRESH_TOKEN_TTL_DAYS=30

# Lifetime (seconds) of per-server scoped tokens minted by /api/auth/server-token
SERVER_TOKEN_TTL=600

# CORS — comma-separated allowlist of browser origins permitted to call this
# API (e.g. your web client). Unset = allow all (dev only, logs a warning).
CORS_ORIGINS=https://app.concordiachat.com

# Outbound email (Resend — https://resend.com). Unset = emails logged, not sent.
RESEND_API_KEY=
EMAIL_FROM="Concordia <no-reply@concordiachat.com>"

# Public origin of this Federation — used as the JWT `iss` claim.
# Verifying services check it, so it must match what they configure as FEDERATION_URL.
PUBLIC_URL=https://federation.concordiachat.com

# Bcrypt — higher = slower hash but more secure (12-14 recommended for prod)
BCRYPT_SALT_ROUNDS=12

# Admin dashboard — UUID of the Concordia account with master admin access
# Must match the user's id in the users table exactly
ADMIN_UUID=your_admin_user_uuid_here

# Internal service-to-service API key (shared with Concordia-Social and other
# first-party services). Use a long random string: openssl rand -hex 32
# Accepts MULTIPLE comma-separated keys to support zero-downtime rotation:
# add the new key, deploy, switch callers over, then remove the old key.
INTERNAL_API_KEY=your_internal_api_key_here
